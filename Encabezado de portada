/* Estilos generales */
body{
    margin:0;
    font-family: Arial, sans-serif;
    background-color:white;
}

/* Encabezado */
header{

    background: linear-gradient(to right, #0b3d91, #d62828);

    color:white;

    text-align:center;

    padding:40px;

}

/* Nombre de la cafetería */

header h1{

    margin:0;

    font-size:48px;

    letter-spacing:3px;

}

/* Eslogan */

header p{

    margin-top:15px;

    font-size:22px;

    font-style:italic;

}



